# ⚡ Antigravity WhatsApp Agent — Variables de entorno
# Copia este archivo a .env y completa tus claves:
#   cp .env.example .env
#
# NUNCA subas el archivo .env a GitHub.

# ── Gemini AI (Motor principal del agente) ─────────────────────
# Obtener gratis en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# ── Proveedor de WhatsApp ──────────────────────────────────────
# Opciones: whapi | meta | twilio
WHATSAPP_PROVIDER=whapi

# ── Whapi.cloud (si WHATSAPP_PROVIDER=whapi) ──────────────────
# Sandbox gratuito disponible en: https://whapi.cloud
WHAPI_TOKEN=

# ── Meta Cloud API (si WHATSAPP_PROVIDER=meta) ────────────────
# Configurar en: https://developers.facebook.com
# META_ACCESS_TOKEN=
# META_PHONE_NUMBER_ID=
# META_VERIFY_TOKEN=antigravity-verify

# ── Twilio (si WHATSAPP_PROVIDER=twilio) ──────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ── Servidor ──────────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development

# ── Base de datos ─────────────────────────────────────────────
# Local (SQLite, para desarrollo):
DATABASE_URL=sqlite+aiosqlite:///./antigravity_agent.db
# Produccion (Supabase PostgreSQL — Antigravity Standard):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
# SUPABASE_URL=https://XXXX.supabase.co
# SUPABASE_ANON_KEY=eyJXXXX...
